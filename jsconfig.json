{
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "moduleResolution": "Bundler",
  "module": "es2022",
  "noEmit": true,
  "lib": [
    "es2022"
  ],
  "types": [
    "@types/node",
    "@types/service-worker-mock",
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ],
  "include": [
    "src",
    "worker-configuration.d.ts"
  ]
}